{
  "name": "@bitcoinerlab/descriptors-scure",
  "version": "3.1.5",
  "description": "This library parses and creates Bitcoin Miniscript Descriptors and generates Partially Signed Bitcoin Transactions (PSBTs). It provides PSBT finalizers and signers for single-signature, BIP32 and Hardware Wallets, bundled for the scure/noble family of libraries.",
  "author": "Jose-Luis Landabaso",
  "license": "MIT",
  "homepage": "https://github.com/bitcoinerlab/descriptors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitcoinerlab/descriptors.git"
  },
  "bugs": {
    "url": "https://github.com/bitcoinerlab/descriptors/issues"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "keywords": [
    "bitcoin",
    "descriptors",
    "miniscript",
    "psbt",
    "scure",
    "noble",
    "btc-signer",
    "bip32"
  ],
  "peerDependencies": {
    "@ledgerhq/ledger-bitcoin": "^0.3.1"
  },
  "peerDependenciesMeta": {
    "@ledgerhq/ledger-bitcoin": {
      "optional": true
    }
  },
  "scripts": {
    "build": "npm --prefix ../.. run build:src && tsc --project ./tsconfig.json",
    "prepack": "npm run build"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ledger": {
      "types": "./dist/ledger.d.ts",
      "default": "./dist/ledger.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@bitcoinerlab/descriptors-core": "3.1.5",
    "@noble/hashes": "^2.0.1",
    "@noble/curves": "^2.0.1",
    "@scure/base": "^2.0.0",
    "@scure/bip32": "^2.0.1",
    "@scure/btc-signer": "^2.0.1"
  }
}
