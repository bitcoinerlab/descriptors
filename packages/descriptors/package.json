{
  "name": "@bitcoinerlab/descriptors",
  "version": "3.1.7",
  "description": "This library parses and creates Bitcoin Miniscript Descriptors and generates Partially Signed Bitcoin Transactions (PSBTs). It provides PSBT finalizers and signers for single-signature, BIP32 and Hardware Wallets, bundled for the bitcoinjs family of libraries.",
  "author": "Jose-Luis Landabaso",
  "license": "MIT",
  "homepage": "https://github.com/bitcoinerlab/descriptors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitcoinerlab/descriptors.git"
  },
  "bugs": {
    "url": "https://github.com/bitcoinerlab/descriptors/issues"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "keywords": [
    "bitcoin",
    "descriptors",
    "miniscript",
    "psbt",
    "bitcoinjs",
    "bitcoinjs-lib",
    "bip32",
    "ecpair"
  ],
  "peerDependencies": {
    "@ledgerhq/ledger-bitcoin": "^0.3.1"
  },
  "peerDependenciesMeta": {
    "@ledgerhq/ledger-bitcoin": {
      "optional": true
    }
  },
  "scripts": {
    "build": "npm --prefix ../.. run build:src && tsc --project ./tsconfig.json",
    "prepublishOnly": "cp ../../README.md README.md && rm -rf dist/ && npm run build"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ledger": {
      "types": "./dist/ledger.d.ts",
      "default": "./dist/ledger.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@bitcoinerlab/descriptors-core": "3.1.7",
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "bip32": "^5.0.1",
    "bitcoinjs-lib": "^7.0.1",
    "ecpair": "^3.0.1"
  }
}
